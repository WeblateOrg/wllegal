"comissions es pot emmascarar mitjançant el Weblate per a protegir la vostra "
"privadesa. Podeu activar-ho al vostre perfil."

#: wllegal/templates/legal/documents/summary.html:15
msgid ""
"You provide your contribution under the license defined by each project you "
"contributed to."
msgstr ""
"Proporcioneu la vostra contribució sota la llicència definida per cada "
"projecte al qual heu contribuït."

#: wllegal/templates/legal/documents/summary.html:18
msgid "We use cookies to deliver our services."
msgstr "Utilitzem galetes per a oferir els nostres serveis."

#: wllegal/templates/legal/documents/summary.html:19
