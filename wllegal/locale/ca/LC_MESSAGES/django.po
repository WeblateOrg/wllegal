#: wllegal/templates/legal/documents/tos.html:456
msgid ""
"Disseminating or offering any content that infringes on third-party "
"intellectual or industrial property rights;"
msgstr ""
"Difondre o oferir qualsevol contingut que infringeixi els drets de propietat "
